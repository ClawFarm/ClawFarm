# =============================================================================
# ClawFarm — Environment Configuration
# =============================================================================

# --- LLM Provider (required) ---
LLM_BASE_URL=http://10.88.100.186:8000/v1
LLM_MODEL=Qwen3.5-122B-A10B
LLM_API_KEY=your-api-key-here
LLM_CONTEXT_WINDOW=128000    # Model context window size (tokens)
LLM_MAX_TOKENS=8192          # Max output tokens per response

# Presets:
#   vLLM local:    LLM_BASE_URL=http://host:8000/v1  LLM_CONTEXT_WINDOW=262144
#   OpenAI:        LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o  LLM_CONTEXT_WINDOW=128000
#   Anthropic:     LLM_BASE_URL=https://api.anthropic.com/v1  LLM_MODEL=claude-sonnet-4-20250514  LLM_CONTEXT_WINDOW=200000
#   OpenRouter:    LLM_BASE_URL=https://openrouter.ai/api/v1  LLM_CONTEXT_WINDOW=128000

# --- Network isolation (iptables rules) ---
LLM_HOST=10.88.100.186
LLM_PORT=8000

# --- TLS / Deployment Mode ---
# TLS_MODE controls how Caddy handles HTTPS. Options:
#   internal  (default) — Caddy auto-generates a self-signed cert. Zero config.
#   acme      — Let's Encrypt auto-provisioned cert. Set DOMAIN and optionally ACME_EMAIL.
#   custom    — Load your own cert from certs/cert.pem + certs/key.pem.
#   off       — Plain HTTP. Use when behind an upstream proxy (nginx, Traefik, Cloudflare).
TLS_MODE=internal

# For TLS_MODE=acme:
# DOMAIN=farm.example.com     # Required — your public domain
# ACME_EMAIL=                  # Optional — for Let's Encrypt notifications
# CADDY_PORT=443               # Standard HTTPS port for public domains

# For TLS_MODE=custom:
#   Place cert at certs/cert.pem and key at certs/key.pem

# For TLS_MODE=off:
# CADDY_PORT=8080              # Plain HTTP port

CADDY_PORT=8443
# PORTAL_URL=                  # Optional — external base URL override for redirects/CORS
#                              # Auto-derived in acme mode (https://DOMAIN).
#                              # Not needed in internal/custom mode (uses request Host header).

# --- Docker ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# --- Agent tools ---
BRAVE_API_KEY=your-brave-api-key-here

# --- Backup settings ---
# BACKUP_DIR=                     # External backup directory (empty = store in bot's .backups/)
BACKUP_INTERVAL_SECONDS=3600      # How often to run scheduled backups (0 = disabled)
BACKUP_KEEP=24                    # Max scheduled backups to retain per bot

# --- Auth settings ---
ADMIN_USER=admin                  # Default admin username (created on first run)
ADMIN_PASSWORD=                   # Admin password (empty = auto-generated, printed to stdout)
SESSION_TTL=86400                 # Session lifetime in seconds (default: 24h)
AUTH_DISABLED=                    # Set to "1" or "true" to disable auth entirely
