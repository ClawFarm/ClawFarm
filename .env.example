# =============================================================================
# ClawFarm — Environment Configuration
# =============================================================================
# Pick ONE LLM provider below. Uncomment the section you need.
# Each provider maps to a bot template — select the matching template when
# creating a bot in the dashboard.

# =============================================================================
# LLM Provider (pick one)
# =============================================================================

# --- Option 1: Anthropic (recommended) ───────────────────────────────────────
# Template: "default"
# Models: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-6       # default

# --- Option 2: OpenAI ────────────────────────────────────────────────────────
# Template: "openai"
# Models: gpt-4o, o3, gpt-4.1, gpt-4.1-mini
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o                     # default

# --- Option 3: MiniMax (budget-friendly) ─────────────────────────────────────
# Template: "minimax"
# MINIMAX_API_KEY=your-minimax-api-key
# MINIMAX_MODEL=MiniMax-M1                # default

# --- Option 4: Qwen via DashScope (budget-friendly) ─────────────────────────
# Template: "qwen"
# QWEN_API_KEY=your-dashscope-api-key
# QWEN_MODEL=qwen-plus                    # default

# --- Option 5: Custom endpoint (vLLM, Ollama, LM Studio, etc.) ──────────────
# Template: "custom-endpoint"
# For self-hosted or OpenAI-compatible inference servers.
# LLM_BASE_URL=http://your-server:8000/v1
# LLM_MODEL=your-model-name
# LLM_API_KEY=your-api-key
# LLM_CONTEXT_WINDOW=128000               # Model context window (tokens)
# LLM_MAX_TOKENS=8192                     # Max output tokens per response

# =============================================================================
# Network isolation (enabled by default)
# =============================================================================
# Bots are blocked from reaching your LAN by default. If your LLM server is
# on the local network, set these so isolated bots can still reach it:
# LLM_HOST=10.0.0.5
# LLM_PORT=8000
#
# To see if isolation is active: sudo iptables -L DOCKER-USER -n | grep CF-

# =============================================================================
# TLS / Deployment Mode
# =============================================================================
# TLS_MODE controls how Caddy handles HTTPS. Options:
#   internal  (default) — Caddy auto-generates a self-signed cert. Zero config.
#   acme      — Let's Encrypt auto-provisioned cert. Set DOMAIN and optionally ACME_EMAIL.
#   custom    — Load your own cert from certs/cert.pem + certs/key.pem.
#   off       — Plain HTTP. Use when behind an upstream proxy (nginx, Traefik, Cloudflare).
TLS_MODE=internal

# CADDY_PORT — host port for accessing the dashboard (default: 8443).
# Only override for acme mode (CADDY_PORT=443) or custom setups.
# CADDY_PORT=8443

# PORTAL_URL — full external URL users type in their browser.
# Required for TLS_MODE=off. Auto-derived in acme mode from DOMAIN.
# Include non-standard port if applicable (e.g., https://farm.example.com:8443).
# PORTAL_URL=

# For TLS_MODE=acme:
# DOMAIN=farm.example.com     # Required — your public domain
# ACME_EMAIL=                  # Optional — for Let's Encrypt notifications
# CADDY_PORT=443               # Standard HTTPS port

# For TLS_MODE=custom:
#   Place cert at certs/cert.pem and key at certs/key.pem

# For TLS_MODE=off (behind upstream proxy):
#   Set PORTAL_URL to your external URL. No port change needed.
#   See docs/deployment.md for proxy configuration examples.

# =============================================================================
# Docker
# =============================================================================
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# =============================================================================
# Agent tools
# =============================================================================
BRAVE_API_KEY=your-brave-api-key-here

# =============================================================================
# Backup settings
# =============================================================================
# BACKUP_DIR=                     # External backup directory (empty = store in bot's .backups/)
BACKUP_INTERVAL_SECONDS=3600      # How often to run scheduled backups (0 = disabled)
BACKUP_KEEP=24                    # Max scheduled backups to retain per bot

# =============================================================================
# Auth settings
# =============================================================================
ADMIN_USER=admin                  # Default admin username (created on first run)
ADMIN_PASSWORD=                   # Admin password (empty = auto-generated, printed to stdout)
SESSION_TTL=86400                 # Session lifetime in seconds (default: 24h)
AUTH_DISABLED=                    # Set to "1" or "true" to disable auth entirely
