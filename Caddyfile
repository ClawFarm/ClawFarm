# Deny-by-default: returns 503 until the dashboard pushes dynamic config.
# This prevents unauthenticated access during the startup window.
# Caddy admin API restricted to requests with Origin: dashboard.
{
	admin :2019 {
		origins dashboard
	}
}

:8080 {
	tls internal {
		on_demand
	}

	respond 503 {
		body "Service starting — please retry in a few seconds."
		close
	}
}
