# Initial Caddyfile — overwritten dynamically by the dashboard via Caddy admin API.
# This static config is used on first startup before the dashboard pushes its config.
# Uses Caddy's internal CA (auto-generated self-signed cert) so no cert files are needed.
# Caddy listens on fixed internal port 8080; Docker Compose maps the host port to it.
{
	admin :2019
}

:8080 {
	tls internal {
		on_demand
	}

	handle /api/* {
		reverse_proxy dashboard:8080
	}

	handle /* {
		reverse_proxy frontend:3000
	}
}
